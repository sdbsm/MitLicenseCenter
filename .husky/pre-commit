#!/usr/bin/env sh
set -e

repo_root="$(git rev-parse --show-toplevel)"

# Git Bash on Windows inherits a limited environment — winget-installed tools
# (pnpm, etc.) are often missing from $PATH.  Add the canonical locations.
case "$(uname -s)" in
  MINGW*|MSYS*|CYGWIN*)
    if command -v cygpath >/dev/null 2>&1 && [ -n "$LOCALAPPDATA" ]; then
      lad="$(cygpath -u "$LOCALAPPDATA")"
      # Standard install locations
      for dir in \
        "$lad/Microsoft/WinGet/Links" \
        "$lad/pnpm" \
        "$lad/Programs/pnpm" \
        "/c/Program Files/dotnet" \
        "/c/Program Files/nodejs"; do
        if [ -d "$dir" ]; then PATH="$dir:$PATH"; fi
      done
      # WinGet Packages layout (hash suffix varies per machine / install source)
      for dir in "$lad"/Microsoft/WinGet/Packages/pnpm.pnpm_*/; do
        if [ -d "$dir" ]; then PATH="$dir:$PATH"; fi
      done
    fi
    export PATH
    ;;
esac

# Hard-fail if required tools are still missing — never silently skip checks.
if ! command -v pnpm >/dev/null 2>&1; then
  echo "pre-commit: pnpm not found on PATH." >&2
  echo "  Install:  winget install pnpm.pnpm" >&2
  echo "  Or fix PATH augmentation in .husky/pre-commit" >&2
  exit 1
fi
if ! command -v dotnet >/dev/null 2>&1; then
  echo "pre-commit: dotnet not found on PATH." >&2
  echo "  Install:  winget install Microsoft.DotNet.SDK.10" >&2
  echo "  Or fix PATH augmentation in .husky/pre-commit" >&2
  exit 1
fi

# 1. Frontend: lint-staged (Prettier/ESLint on staged JS/TS/JSON/CSS).
if [ -f "$repo_root/frontend/package.json" ]; then
  staged_fe="$(git diff --cached --name-only --diff-filter=ACMR \
    -- 'frontend/**/*.ts' 'frontend/**/*.tsx' \
       'frontend/**/*.js' 'frontend/**/*.jsx' \
       'frontend/**/*.json' 'frontend/**/*.css' \
       'frontend/**/*.md' 'frontend/**/*.html' \
    || true)"
  if [ -n "$staged_fe" ]; then
    (cd "$repo_root/frontend" && pnpm exec lint-staged)
  fi
fi

# 2. Backend: dotnet format on staged .cs files.
staged_cs="$(git diff --cached --name-only --diff-filter=ACM -- '*.cs' || true)"
if [ -n "$staged_cs" ]; then
  cs_files="$(echo "$staged_cs" | tr '\n' ' ')"
  # shellcheck disable=SC2086  # word-splitting intentional for the file list
  (cd "$repo_root" && dotnet format backend/MitLicenseCenter.slnx \
    --include $cs_files --verify-no-changes --severity warn)
fi

exit 0
