#!/usr/bin/env sh
set -e

repo_root="$(git rev-parse --show-toplevel)"

# Git Bash на Windows не наследует все Windows-каталоги в $PATH —
# добавляем стандартные места установки dotnet и winget-инструментов вручную.
case "$(uname -s)" in
  MINGW*|MSYS*|CYGWIN*)
    for dir in \
      "/c/Program Files/dotnet" \
      "/c/Users/$USER/AppData/Local/Microsoft/WinGet/Links" \
      "/c/Users/$USER/AppData/Local/pnpm" \
      "/c/Users/$USER/AppData/Roaming/npm" \
      "/c/Program Files/nodejs"; do
      if [ -d "$dir" ]; then PATH="$dir:$PATH"; fi
    done
    export PATH
    ;;
esac

# 1. Frontend: lint-staged (Prettier/ESLint на staged JS/TS/JSON/CSS).
if [ -f "$repo_root/frontend/package.json" ]; then
  staged_fe="$(git diff --cached --name-only --diff-filter=ACMR -- 'frontend/**/*.ts' 'frontend/**/*.tsx' 'frontend/**/*.js' 'frontend/**/*.jsx' 'frontend/**/*.json' 'frontend/**/*.css' 'frontend/**/*.md' 'frontend/**/*.html' || true)"
  if [ -n "$staged_fe" ]; then
    if command -v pnpm >/dev/null 2>&1; then
      (cd "$repo_root/frontend" && pnpm exec lint-staged)
    else
      echo "[pre-commit] pnpm не найден в PATH — фронтенд-проверки пропущены." >&2
    fi
  fi
fi

# 2. Backend: dotnet format на staged .cs.
staged_cs="$(git diff --cached --name-only --diff-filter=ACM -- '*.cs' || true)"
if [ -n "$staged_cs" ]; then
  if command -v dotnet >/dev/null 2>&1; then
    cs_files="$(echo "$staged_cs" | tr '\n' ' ')"
    (cd "$repo_root" && dotnet format backend/MitLicenseCenter.slnx --include $cs_files --verify-no-changes --severity warn)
  else
    echo "[pre-commit] dotnet не найден в PATH — backend-проверки пропущены." >&2
  fi
fi

exit 0
